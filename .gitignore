# Dependencies
node_modules/

# Build output (Vite)
dist/

# Gatsby leftovers
.cache/

# public/ contains Vite static assets — ignore everything except what we explicitly track
/public/*
!/public/favicon.svg
!/public/resume.pdf
!/public/robots.txt
!/public/sitemap.xml

# Claude memory/plans (local only)
.claude/

# Env / secrets
.env
.env.*
!.env.example

# Editor
.DS_Store
.vscode/
*.swp
